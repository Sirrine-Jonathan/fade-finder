{
  "name": "fade-finder",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "NODE_PATH=./node_modules npx vitest run",
    "test:e2e": "NODE_PATH=./node_modules npx @playwright/test test",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:unseed": "node prisma/unseed.js",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "db:reset:empty": "prisma db push --force-reset && node prisma/unseed.js",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@playwright/test": "^1.50.1",
    "@prisma/client": "^6.4.1",
    "lucide-react": "^0.475.0",
    "next": "^16.2.10",
    "prisma": "^6.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "styled-components": "^6.1.15",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/styled-components": "^5.1.34",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^26.0.0",
    "typescript": "^5",
    "vitest": "^3.0.5"
  }
}
